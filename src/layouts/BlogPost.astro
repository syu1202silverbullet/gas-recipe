---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import AuthorCard from '../components/AuthorCard.astro';
import SideFireLink from '../components/SideFireLink.astro';
import MobileNav from '../components/MobileNav.astro';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string };

const props: any = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, categorySlug, categoryName, tagSlugs, tagNames, readingTime } = props;
const currentSlug = Astro.params.slug;

const now = new Date();
const allPosts = (await getCollection('blog'))
	.filter((p: any) => p.data.pubDate.valueOf() <= now.valueOf())
	.filter((p: any) => p.id !== currentSlug);

const related = allPosts
	.map((p: any) => {
		let score = 0;
		if (p.data.categorySlug === categorySlug) score += 3;
		const pTags = p.data.tagSlugs || [];
		pTags.forEach((t: string) => { if ((tagSlugs || []).includes(t)) score += 1; });
		return { post: p, score };
	})
	.sort((a, b) => b.score - a.score || Math.random() - 0.5)
	.slice(0, 4)
	.map((x: any) => x.post);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={title} description={description} image={heroImage} pubDate={pubDate} updatedDate={updatedDate} type="article" />
		<style>
			main { width: 100%; padding-bottom: 4em; }
			.hero-image { width: 100%; max-width: 960px; margin: 0 auto 1.5rem; }
			.hero-image img { display: block; margin: 0 auto; border-radius: 12px; box-shadow: var(--box-shadow); width: 100%; height: auto; }
			.prose { width: 760px; max-width: calc(100% - 2em); margin: auto; padding: 1rem; color: rgb(var(--gray-dark)); }

			.progress-bar {
				position: fixed;
				top: 0; left: 0;
				height: 3px;
				background: var(--accent);
				z-index: 9999;
				width: 0%;
				transition: width 0.15s linear;
			}

			.breadcrumbs { font-size: 0.85em; color: rgb(var(--gray)); margin-bottom: 1rem; }
			.breadcrumbs a { color: var(--accent); text-decoration: none; }
			.breadcrumbs a:hover { text-decoration: underline; }

			.category-chip {
				display: inline-block;
				padding: 0.3em 0.9em;
				background: var(--accent);
				color: white;
				border-radius: 999px;
				font-size: 0.8em;
				font-weight: 600;
				text-decoration: none;
				margin-bottom: 0.8rem;
			}
			.category-chip:hover { background: var(--accent-dark); border: none; }

			.title { margin: 0 0 1.5rem 0; padding: 0; line-height: 1.3; }
			.title h1 { margin: 0 0 0.8rem 0; font-size: 1.9em; line-height: 1.4; }
			.meta-row {
				display: flex;
				flex-wrap: wrap;
				gap: 1.2rem;
				color: rgb(var(--gray));
				font-size: 0.88em;
				align-items: center;
				padding: 0.5rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 1.5rem;
			}
			.meta-item { display: inline-flex; align-items: center; gap: 0.3em; }
			.last-updated-on { font-style: italic; }

			.ad-notice {
				background: #fef3c7;
				border: 1px solid #fcd34d;
				color: #78350f;
				padding: 0.7rem 1rem;
				border-radius: 8px;
				font-size: 0.85em;
				margin: 0 0 1.5rem 0;
			}

			.tags-list { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 1.5rem 0 2rem; padding: 1rem; background: var(--bg-soft); border-radius: 8px; }
			.tag-chip {
				display: inline-block;
				padding: 0.3em 0.8em;
				background: var(--bg);
				color: rgb(var(--gray-dark));
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				font-size: 0.82em;
				text-decoration: none;
				transition: all 0.15s;
			}
			.tag-chip:hover { background: var(--accent-light); color: var(--accent-dark); border-color: var(--accent); }
			.tags-label { font-size: 0.85em; color: rgb(var(--gray)); align-self: center; }

			.toc { background: var(--bg-soft); border-left: 4px solid var(--accent); border-radius: 0 var(--radius) var(--radius) 0; padding: 1rem 1.5rem; margin: 1.5rem 0 2rem; }
			.toc-title { margin: 0 0 0.5rem 0; font-weight: 700; font-size: 0.95em; color: rgb(var(--black)); cursor: pointer; user-select: none; }
			.toc-title::after { content: ' ▾'; font-size: 0.8em; }
			.toc.collapsed .toc-title::after { content: ' ▸'; }
			.toc.collapsed ul { display: none; }
			.toc ul { margin: 0; padding-left: 1.3rem; font-size: 0.92em; }
			.toc li { margin-bottom: 0.3rem; }
			.toc a { color: rgb(var(--gray-dark)); text-decoration: none; border-bottom: 1px dashed transparent; }
			.toc a:hover { color: var(--accent); border-bottom-color: var(--accent); }

			.related { margin-top: 3rem; padding: 1.5rem; background: var(--bg-soft); border-radius: var(--radius); }
			.related h2 { margin-top: 0; border: none; padding: 0; background: none; font-size: 1.2em; }
			.related ul { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
			.related li { margin: 0; }
			.related a { display: block; padding: 0.8rem 1rem; background: var(--bg); border-radius: 8px; text-decoration: none; color: rgb(var(--black)); border: 1px solid rgb(var(--gray-light)); font-weight: 500; transition: all 0.15s; font-size: 0.92em; line-height: 1.5; }
			.related a:hover { transform: translateY(-2px); box-shadow: var(--box-shadow); color: var(--accent); }
			@media (max-width: 720px) {
				.related ul { grid-template-columns: 1fr; }
				.title h1 { font-size: 1.4em; }
			}

			.share-buttons {
				display: flex;
				gap: 0.6rem;
				margin: 2rem 0;
				justify-content: center;
				flex-wrap: wrap;
			}
			.share-buttons a {
				display: inline-flex;
				align-items: center;
				padding: 0.5em 1em;
				border-radius: 999px;
				font-size: 0.85em;
				font-weight: 600;
				text-decoration: none;
				border: 1px solid rgb(var(--gray-light));
				background: var(--bg);
				color: rgb(var(--gray-dark));
			}
			.share-buttons a:hover { background: var(--bg-soft); border-color: var(--accent); color: var(--accent); }
		</style>
	</head>

	<body>
		<div class="progress-bar" id="read-progress"></div>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<img width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="prose">
					<nav class="breadcrumbs" aria-label="パンくずリスト">
						<a href="/">ホーム</a> <span>›</span>
						<a href="/blog/">記事一覧</a>
						{categorySlug && (<><span>›</span> <a href={`/category/${categorySlug}/`}>{categoryName}</a></>)}
					</nav>

					{categorySlug && (
						<a class="category-chip" href={`/category/${categorySlug}/`}>📂 {categoryName}</a>
					)}

					<div class="title">
						<h1>{title}</h1>
						<div class="meta-row">
							<span class="meta-item">📅 <FormattedDate date={pubDate} /></span>
							{updatedDate && (<span class="meta-item last-updated-on">🔄 <FormattedDate date={updatedDate} /></span>)}
							{readingTime && (<span class="meta-item">⏱ 読了 約{readingTime}分</span>)}
						</div>
					</div>

					<p class="ad-notice">💡 本記事には広告（アフィリエイトリンク）が含まれる場合があります。</p>

					<div id="article-body">
						<slot />
					</div>

					<div class="share-buttons">
						<a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent('https://gas-recipe.com/blog/' + currentSlug + '/')}`} target="_blank" rel="noopener">𝕏 Xでシェア</a>
						<a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent('https://gas-recipe.com/blog/' + currentSlug + '/')}`} target="_blank" rel="noopener">Facebookでシェア</a>
						<a href={`https://b.hatena.ne.jp/entry/${encodeURIComponent('https://gas-recipe.com/blog/' + currentSlug + '/')}`} target="_blank" rel="noopener">はてブ</a>
					</div>

					{tagNames && tagNames.length > 0 && (
						<div class="tags-list">
							<span class="tags-label">タグ:</span>
							{tagNames.map((name: string, i: number) => (
								<a class="tag-chip" href={`/tag/${tagSlugs[i]}/`}>#{name}</a>
							))}
						</div>
					)}

					<AuthorCard />

					<SideFireLink />

					{related.length > 0 && (
						<aside class="related">
							<h2>あわせて読みたい</h2>
							<ul>
								{related.map((p: any) => (
									<li><a href={`/blog/${p.id}/`}>{p.data.title}</a></li>
								))}
							</ul>
						</aside>
					)}
				</div>
			</article>
		</main>
		<Footer />
		<MobileNav />

		<script is:inline>
			// TOC + reading progress
			(function() {
				const body = document.getElementById('article-body');
				if (body) {
					const headings = body.querySelectorAll('h2, h3');
					if (headings.length >= 2) {
						const toc = document.createElement('nav');
						toc.className = 'toc';
						toc.setAttribute('aria-label', '目次');
						const title = document.createElement('p');
						title.className = 'toc-title';
						title.textContent = '📑 目次';
						title.addEventListener('click', () => toc.classList.toggle('collapsed'));
						toc.appendChild(title);
						const ul = document.createElement('ul');
						headings.forEach((h, i) => {
							if (!h.id) h.id = 'h-' + i;
							const li = document.createElement('li');
							if (h.tagName === 'H3') li.style.marginLeft = '1em';
							const a = document.createElement('a');
							a.href = '#' + h.id;
							a.textContent = h.textContent;
							li.appendChild(a);
							ul.appendChild(li);
						});
						toc.appendChild(ul);
						body.insertBefore(toc, body.firstChild);
					}
				}

				// Scroll progress bar
				const bar = document.getElementById('read-progress');
				if (bar) {
					window.addEventListener('scroll', () => {
						const scroll = window.scrollY;
						const height = document.documentElement.scrollHeight - window.innerHeight;
						const p = height > 0 ? (scroll / height) * 100 : 0;
						bar.style.width = p + '%';
					}, { passive: true });
				}
			})();
		</script>
	
<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
	document.querySelectorAll('pre').forEach(pre => {
		if (pre.querySelector('.copy-btn')) return;
		const btn = document.createElement('button');
		btn.className = 'copy-btn';
		btn.textContent = 'Copy';
		btn.addEventListener('click', async () => {
			const code = pre.querySelector('code')?.textContent || pre.textContent;
			try {
				await navigator.clipboard.writeText(code);
				btn.textContent = 'Copied!';
				btn.classList.add('copied');
				setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
			} catch (e) {
				btn.textContent = 'Failed';
			}
		});
		pre.appendChild(btn);
	});
});
</script>

	</body>
</html>
