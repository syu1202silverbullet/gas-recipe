---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string };

const { title, description, pubDate, updatedDate, heroImage, category, tags } = Astro.props as any;
const currentSlug = Astro.params.slug;

const now = new Date();
const allPosts = (await getCollection('blog'))
	.filter((p) => p.data.pubDate.valueOf() <= now.valueOf())
	.filter((p) => p.id !== currentSlug);

// Related posts by same category or tag
const currentCategory = (Astro.props as any).category;
const currentTags = (Astro.props as any).tags || [];
const related = allPosts
	.map((p) => {
		let score = 0;
		if (p.data.category === currentCategory) score += 3;
		const pTags = (p.data as any).tags || [];
		pTags.forEach((t: string) => { if (currentTags.includes(t)) score += 1; });
		return { post: p, score };
	})
	.sort((a, b) => b.score - a.score || Math.random() - 0.5)
	.slice(0, 3)
	.map((x) => x.post);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			pubDate={pubDate}
			updatedDate={updatedDate}
			type="article"
		/>
		<style>
			main { width: 100%; }
			.hero-image { width: 100%; max-width: 960px; margin: 0 auto 1.5rem; }
			.hero-image img { display: block; margin: 0 auto; border-radius: 12px; box-shadow: var(--box-shadow); width: 100%; height: auto; }
			.prose { width: 760px; max-width: calc(100% - 2em); margin: auto; padding: 1rem; color: rgb(var(--gray-dark)); }
			.breadcrumbs { font-size: 0.85em; color: rgb(var(--gray)); margin-bottom: 1rem; }
			.breadcrumbs a { color: var(--accent); text-decoration: none; }
			.breadcrumbs a:hover { text-decoration: underline; }

			.category-chip {
				display: inline-block;
				padding: 0.3em 0.9em;
				background: var(--accent);
				color: white;
				border-radius: 999px;
				font-size: 0.8em;
				font-weight: 600;
				text-decoration: none;
				margin-bottom: 0.8rem;
			}
			.category-chip:hover { background: var(--accent-dark); border: none; }

			.title { margin: 0 0 1.5rem 0; padding: 0; line-height: 1.3; }
			.title h1 { margin: 0 0 0.8rem 0; font-size: 1.9em; line-height: 1.4; }
			.date { margin-bottom: 0.5rem; color: rgb(var(--gray)); font-size: 0.9em; }
			.last-updated-on { font-style: italic; }

			.tags-list { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 1.5rem 0 2rem; padding: 1rem; background: var(--bg-soft); border-radius: 8px; }
			.tag-chip {
				display: inline-block;
				padding: 0.3em 0.8em;
				background: var(--bg);
				color: rgb(var(--gray-dark));
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				font-size: 0.82em;
				text-decoration: none;
				transition: all 0.15s;
			}
			.tag-chip:hover { background: var(--accent-light); color: var(--accent-dark); border-color: var(--accent); }
			.tags-label { font-size: 0.85em; color: rgb(var(--gray)); align-self: center; }

			.toc { background: var(--bg-soft); border-left: 4px solid var(--accent); border-radius: 0 var(--radius) var(--radius) 0; padding: 1rem 1.5rem; margin: 1.5rem 0 2rem; }
			.toc-title { margin: 0 0 0.5rem 0; font-weight: 700; font-size: 0.95em; color: rgb(var(--black)); }
			.toc ul { margin: 0; padding-left: 1.3rem; font-size: 0.92em; }
			.toc li { margin-bottom: 0.3rem; }
			.toc a { color: rgb(var(--gray-dark)); text-decoration: none; border-bottom: 1px dashed transparent; }
			.toc a:hover { color: var(--accent); border-bottom-color: var(--accent); }

			.related { margin-top: 3rem; padding: 1.5rem; background: var(--bg-soft); border-radius: var(--radius); }
			.related h2 { margin-top: 0; border: none; padding: 0; background: none; font-size: 1.2em; }
			.related ul { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr; gap: 0.8rem; }
			.related li { margin: 0; }
			.related a { display: block; padding: 0.8rem 1rem; background: var(--bg); border-radius: 8px; text-decoration: none; color: rgb(var(--black)); border: 1px solid rgb(var(--gray-light)); font-weight: 500; transition: all 0.15s; }
			.related a:hover { transform: translateY(-2px); box-shadow: var(--box-shadow); color: var(--accent); }
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<img width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="prose">
					<nav class="breadcrumbs" aria-label="パンくずリスト">
						<a href="/">ホーム</a> <span>›</span>
						<a href="/blog/">記事一覧</a>
						{category && (<><span>›</span> <a href={`/category/${encodeURIComponent(category)}/`}>{category}</a></>)}
					</nav>

					{category && (
						<a class="category-chip" href={`/category/${encodeURIComponent(category)}/`}>📂 {category}</a>
					)}

					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && (<div class="last-updated-on">最終更新: <FormattedDate date={updatedDate} /></div>)}
						</div>
						<h1>{title}</h1>
					</div>

					<div id="article-body">
						<slot />
					</div>

					{tags && tags.length > 0 && (
						<div class="tags-list">
							<span class="tags-label">タグ:</span>
							{tags.map((t: string) => (
								<a class="tag-chip" href={`/tag/${encodeURIComponent(t)}/`}>#{t}</a>
							))}
						</div>
					)}

					{related.length > 0 && (
						<aside class="related">
							<h2>関連記事</h2>
							<ul>
								{related.map((p: any) => (
									<li><a href={`/blog/${p.id}/`}>{p.data.title}</a></li>
								))}
							</ul>
						</aside>
					)}
				</div>
			</article>
		</main>
		<Footer />

		<script is:inline>
			(function() {
				const body = document.getElementById('article-body');
				if (!body) return;
				const headings = body.querySelectorAll('h2, h3');
				if (headings.length < 2) return;
				const toc = document.createElement('nav');
				toc.className = 'toc';
				toc.setAttribute('aria-label', '目次');
				const title = document.createElement('p');
				title.className = 'toc-title';
				title.textContent = '📑 目次';
				toc.appendChild(title);
				const ul = document.createElement('ul');
				headings.forEach((h, i) => {
					if (!h.id) h.id = 'h-' + i;
					const li = document.createElement('li');
					if (h.tagName === 'H3') li.style.marginLeft = '1em';
					const a = document.createElement('a');
					a.href = '#' + h.id;
					a.textContent = h.textContent;
					li.appendChild(a);
					ul.appendChild(li);
				});
				toc.appendChild(ul);
				body.insertBefore(toc, body.firstChild);
			})();
		</script>
	</body>
</html>
