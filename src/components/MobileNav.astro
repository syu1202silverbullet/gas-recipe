<nav class="mobile-nav" aria-label="モバイルナビゲーション">
	<a href="/" class="mnav-item"><span class="mnav-icon">🏠</span><span class="mnav-label">ホーム</span></a>
	<a href="/blog/" class="mnav-item"><span class="mnav-icon">📚</span><span class="mnav-label">記事</span></a>
	<a href="/about/" class="mnav-item"><span class="mnav-icon">👤</span><span class="mnav-label">運営者</span></a>
	<a href="/contact/" class="mnav-item"><span class="mnav-icon">✉️</span><span class="mnav-label">連絡</span></a>
</nav>
<style>
	.mobile-nav {
		display: none;
		position: fixed;
		bottom: 0; left: 0; right: 0;
		background: white;
		border-top: 1px solid rgb(var(--gray-light));
		padding: 0.5rem 0 env(safe-area-inset-bottom, 0.3rem);
		justify-content: space-around;
		z-index: 90;
		box-shadow: 0 -2px 8px rgba(0,0,0,0.05);
	}
	.mnav-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.2em;
		padding: 0.4rem 0.6rem;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-size: 0.72em;
		border: none;
		flex: 1;
		text-align: center;
	}
	.mnav-icon { font-size: 1.3em; }
	.mnav-item:hover { color: var(--accent); }
	@media (max-width: 720px) {
		.mobile-nav { display: flex; }
		body { padding-bottom: 4rem; }
	}
	@media (prefers-color-scheme: dark) {
		.mobile-nav { background: var(--bg-soft); border-top-color: rgb(var(--gray-light)); }
	}
</style>
