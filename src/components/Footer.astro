---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p class="footer-nav">
			<a href="/">ホーム</a>
			<a href="/blog/">記事一覧</a>
			<a href="/about/">運営者情報</a>
			<a href="/privacy/">プライバシーポリシー</a>
			<a href="/contact/">お問い合わせ</a>
		</p>
		<p class="asp-notice">
			当サイトはA8.net・もしもアフィリエイト・アクセストレード等のアフィリエイト・プログラムに参加しています。
		</p>
		<p class="copyright">&copy; {today.getFullYear()} GAS Recipe｜All rights reserved.</p>
	</div>
</footer>
<style>
	footer {
		padding: 2.5em 1em 3em;
		background: var(--bg-soft);
		color: rgb(var(--gray));
		text-align: center;
		font-size: 0.88em;
		border-top: 1px solid rgb(var(--gray-light));
		margin-top: 4em;
	}
	.footer-inner {
		max-width: 760px;
		margin: 0 auto;
	}
	.footer-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 1.2em;
		justify-content: center;
		margin: 0 0 1em 0;
	}
	.footer-nav a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	.footer-nav a:hover { color: var(--accent); }
	.asp-notice {
		font-size: 0.82em;
		margin: 0 0 1em 0;
		line-height: 1.7;
	}
	.copyright { margin: 0; }
</style>
