---
import { SITE_TITLE } from '../consts';
const pathname = Astro.url.pathname;
const isActive = (href: string) => {
	if (href === '/') return pathname === '/';
	return pathname === href || pathname.startsWith(href);
};
---

<div class="ad-disclosure">本サイトはアフィリエイト広告（A8.net／もしもアフィリエイト／アクセストレード等）を利用しています</div>
<header>
	<nav class="main-nav">
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<div class="nav-links">
			<a href="/" class:list={[isActive('/') && 'active']}>ホーム</a>
			<a href="/guide/" class:list={[isActive('/guide/') && 'active']}>GAS完全ガイド</a>
			<a href="/blog/" class:list={[isActive('/blog/') && 'active']}>記事一覧</a>
			<a href="/about/" class:list={[isActive('/about/') && 'active']}>運営者</a>
			<a href="/contact/" class:list={[isActive('/contact/') && 'active']}>お問い合わせ</a>
		</div>
	</nav>
</header>
<style>
	.ad-disclosure {
		background: #fef3c7;
		color: #78350f;
		padding: 0.45rem 1rem;
		text-align: center;
		font-size: 0.78em;
		border-bottom: 1px solid #fcd34d;
	}
	header {
		background: white;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
		position: sticky;
		top: 0;
		z-index: 80;
	}
	.main-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.6rem 1rem;
		max-width: 960px;
		margin: 0 auto;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.site-title {
		font-size: 1em;
		font-weight: 700;
		color: rgb(var(--black));
		text-decoration: none;
		border: none;
	}
	.nav-links {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
	}
	.nav-links a {
		padding: 0.5em 0.7em;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		border: none;
		border-bottom: 2px solid transparent;
		font-size: 0.9em;
		font-weight: 500;
	}
	.nav-links a.active {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}
	.nav-links a:hover { color: var(--accent); }

	@media (max-width: 720px) {
		.main-nav { flex-direction: column; align-items: flex-start; gap: 0.3rem; }
		.nav-links { width: 100%; justify-content: space-around; font-size: 0.8em; }
		.nav-links a { padding: 0.4em 0.3em; }
	}
	@media (prefers-color-scheme: dark) {
		header { background: var(--bg-soft); }
	}
</style>
