---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<div class="ad-disclosure">本サイトはアフィリエイト広告（A8.net、もしもアフィリエイト、アクセストレード等）を利用しています</div>
<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">ホーム</HeaderLink>
			<HeaderLink href="/blog/">記事一覧</HeaderLink>
			<HeaderLink href="/about/">運営者情報</HeaderLink>
			<HeaderLink href="/contact/">お問い合わせ</HeaderLink>
			<HeaderLink href="/privacy/">プライバシー</HeaderLink>
		</div>
	</nav>
</header>
<style>
	.ad-disclosure {
		background: #fef3c7;
		color: #78350f;
		padding: 0.45rem 1rem;
		text-align: center;
		font-size: 0.82em;
		border-bottom: 1px solid #fcd34d;
	}
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a, h2 a.active { text-decoration: none; }
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	@media (max-width: 720px) {
		.internal-links { padding: 0.5em; font-size: 0.85em; }
		nav { flex-direction: column; }
	}
</style>
