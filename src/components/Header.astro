---
import { SITE_TITLE } from '../consts';
const pathname = Astro.url.pathname;
const isActive = (href: string) => {
	if (href === '/') return pathname === '/';
	return pathname === href || pathname.startsWith(href);
};
---

<div class="ad-disclosure">本サイトはアフィリエイト広告（A8.net／もしもアフィリエイト／アクセストレード等）を利用しています</div>
<header>
	<nav class="main-nav">
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<div class="nav-links">
			<a href="/" class:list={[isActive('/') && 'active']}>ホーム</a>
			<a href="/guide/" class:list={[isActive('/guide/') && 'active']}>GAS完全ガイド</a>
			<a href="/blog/" class:list={[isActive('/blog/') && 'active']}>記事一覧</a>
			<a href="/products/" class:list={[isActive('/products/') && 'active', 'nav-highlight']}>🛍️ テンプレート</a>
			<a href="/usecase/" class:list={[isActive('/usecase/') && 'active']}>ユースケース</a>
			<a href="/errors/" class:list={[isActive('/errors/') && 'active']}>エラー逆引き</a>
			<a href="/about/" class:list={[isActive('/about/') && 'active']}>運営者</a>
		</div>
	</nav>
</header>
<style>
	.ad-disclosure {
		background: #fef3c7;
		color: #78350f;
		padding: 0.45rem 1rem;
		text-align: center;
		font-size: 0.78em;
		border-bottom: 1px solid #fcd34d;
	}
	header {
		background: white;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
		position: sticky;
		top: 0;
		z-index: 80;
	}
	.main-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.6rem 1rem;
		max-width: 1040px;
		margin: 0 auto;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.site-title {
		font-size: 1em;
		font-weight: 700;
		color: rgb(var(--black));
		text-decoration: none;
		border: none;
	}
	.nav-links {
		display: flex;
		gap: 0.3rem;
		flex-wrap: wrap;
	}
	.nav-links a {
		padding: 0.5em 0.6em;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		border: none;
		border-bottom: 2px solid transparent;
		font-size: 0.88em;
		font-weight: 500;
	}
	.nav-links a.active {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}
	.nav-links a:hover { color: var(--accent); }
	.nav-links a.nav-highlight {
		color: var(--accent);
		font-weight: 700;
	}
	.nav-links a.nav-highlight.active {
		background: var(--accent);
		color: white;
		border-radius: 6px;
		border-bottom-color: transparent;
	}

	@media (max-width: 720px) {
		.main-nav { flex-direction: column; align-items: flex-start; gap: 0.3rem; }
		.nav-links { width: 100%; justify-content: space-around; font-size: 0.78em; gap: 0.1rem; }
		.nav-links a { padding: 0.4em 0.25em; }
	}
	@media (prefers-color-scheme: dark) {
		header { background: var(--bg-soft); }
	}
</style>
