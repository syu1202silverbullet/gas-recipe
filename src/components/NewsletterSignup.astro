---
// PMが Google Form を作成したら form action URL を差し替えてください
// 現状は /lp/gas-starter/ にフォールバック誘導
const FORM_URL = '/lp/gas-starter/';
---
<aside class="newsletter">
	<div class="nl-inner">
		<div class="nl-body">
			<p class="nl-eyebrow">📬 限定プレゼント</p>
			<h3>「GAS副業で月5万円」スタートガイドPDF（無料）</h3>
			<p class="nl-lead">
				看護師ママがGASで副業月5万円を目指した最初の90日間の実録。
				基礎文法・最初の案件の取り方・確定申告の落とし穴まで、全23ページのPDFをメールでお届けします。
			</p>
			<ul class="nl-features">
				<li>✅ GAS初学者が最初の3ヶ月でやるべきことリスト</li>
				<li>✅ 副業月5万円を継続する3つの仕組み</li>
				<li>✅ 失敗しない案件の選び方テンプレ</li>
			</ul>
			<a href={FORM_URL} class="nl-btn">無料で受け取る →</a>
			<p class="nl-note">※メールアドレスのみ登録、いつでも解除できます</p>
		</div>
	</div>
</aside>
<style>
	.newsletter {
		margin: 2.5rem 0;
		background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
		border: 1px solid #93c5fd;
		border-radius: var(--radius);
		padding: 1.8rem 1.6rem;
	}
	.nl-eyebrow {
		display: inline-block;
		padding: 0.25em 0.8em;
		background: var(--accent);
		color: white;
		border-radius: 999px;
		font-size: 0.78em;
		font-weight: 600;
		margin: 0 0 0.8rem;
	}
	.newsletter h3 {
		margin: 0 0 0.6rem;
		font-size: 1.15em;
		color: rgb(var(--black));
		line-height: 1.4;
	}
	.nl-lead { margin: 0 0 0.9rem; font-size: 0.92em; line-height: 1.7; color: rgb(var(--gray-dark)); }
	.nl-features {
		list-style: none;
		padding: 0;
		margin: 0 0 1.2rem;
		font-size: 0.88em;
		line-height: 1.9;
		color: rgb(var(--gray-dark));
	}
	.nl-features li { padding: 0; }
	.nl-btn {
		display: inline-block;
		padding: 0.8em 1.6em;
		background: var(--accent);
		color: white;
		border: none;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 700;
		font-size: 0.95em;
		box-shadow: 0 4px 10px rgba(59, 130, 246, 0.25);
		transition: transform 0.15s;
	}
	.nl-btn:hover { transform: translateY(-1px); color: white; }
	.nl-note {
		margin: 0.7rem 0 0;
		font-size: 0.78em;
		color: rgb(var(--gray));
	}
	@media (prefers-color-scheme: dark) {
		.newsletter {
			background: linear-gradient(135deg, #1e293b 0%, #1e3a8a 100%);
			border-color: #3b82f6;
		}
		.newsletter h3 { color: #f1f5f9; }
		.nl-lead, .nl-features { color: #cbd5e1; }
	}
</style>
