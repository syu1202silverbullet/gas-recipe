---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileNav from '../components/MobileNav.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`テンプレート｜準備中 | ${SITE_TITLE}`}
			description="GAS Recipeのテンプレート販売は現在準備中です。"
		/>
		<meta name="robots" content="noindex, nofollow" />
	</head>
	<body>
		<Header />
		<main>
			<section class="coming-soon">
				<p class="eyebrow">🛠️ Coming Soon</p>
				<h1>テンプレート販売は準備中です</h1>
				<p class="lead">
					現在、GAS Recipeのテンプレート販売に向けた準備を進めています。<br/>
					準備が整い次第、あらためてご案内します。
				</p>
				<a href="/" class="back-btn">← トップに戻る</a>
			</section>
		</main>
		<Footer />
		<MobileNav />
		<style>
			main { width: 760px; max-width: calc(100% - 2rem); margin: 0 auto; padding: 4rem 1rem; }
			.coming-soon { text-align: center; padding: 3rem 1rem; }
			.eyebrow {
				display: inline-block;
				padding: 0.3em 1em;
				background: var(--bg-soft);
				border-radius: 999px;
				font-size: 0.85em;
				font-weight: 700;
				color: rgb(var(--gray-dark));
				margin: 0 0 1rem;
			}
			h1 { margin: 0 0 1.5rem; border: none; padding: 0; color: rgb(var(--black)); }
			.lead { color: rgb(var(--gray-dark)); line-height: 1.9; margin: 0 0 2rem; }
			.back-btn {
				display: inline-block;
				padding: 0.7em 2em;
				background: var(--accent);
				color: white;
				border-radius: 999px;
				text-decoration: none;
				font-weight: 600;
			}
		</style>
	</body>
</html>
