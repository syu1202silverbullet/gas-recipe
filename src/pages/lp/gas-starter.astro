---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import MobileNav from '../../components/MobileNav.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`準備中 | ${SITE_TITLE}`}
			description="こちらのページは現在準備中です。"
		/>
		<meta name="robots" content="noindex, nofollow" />
	</head>
	<body>
		<main>
			<section class="coming-soon">
				<h1>ページは準備中です</h1>
				<p>現在準備を進めております。もうしばらくお待ちください。</p>
				<a href="/" class="back-btn">← トップに戻る</a>
			</section>
		</main>
		<Footer />
		<MobileNav />
		<style>
			main { width: 640px; max-width: calc(100% - 2rem); margin: 0 auto; padding: 4rem 1rem; }
			.coming-soon { text-align: center; padding: 3rem 1rem; }
			h1 { margin: 0 0 1.5rem; border: none; padding: 0; color: rgb(var(--black)); }
			p { color: rgb(var(--gray-dark)); line-height: 1.9; margin: 0 0 2rem; }
			.back-btn {
				display: inline-block;
				padding: 0.7em 2em;
				background: var(--accent);
				color: white;
				border-radius: 999px;
				text-decoration: none;
				font-weight: 600;
			}
		</style>
	</body>
</html>
