---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileNav from '../components/MobileNav.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`サイト内検索 | ${SITE_TITLE}`} description="GAS Recipeのサイト内検索。キーワードから目的のGASレシピを素早く探せます。" />
		<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
		<script src="/pagefind/pagefind-ui.js" is:inline></script>
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumbs" aria-label="パンくずリスト">
				<a href="/">ホーム</a> <span>›</span> 検索
			</nav>
			<h1>🔍 サイト内検索</h1>
			<p class="lead">キーワードを入力して、gas-recipe.com 内の記事を検索できます。</p>
			<div id="search" class="search-wrap"></div>
		</main>
		<Footer />
		<MobileNav />
		<script is:inline>
			window.addEventListener('DOMContentLoaded', () => {
				new PagefindUI({
					element: '#search',
					showSubResults: true,
					showImages: false,
					translations: {
						placeholder: 'GASのレシピを検索…',
						clear_search: 'クリア',
						load_more: 'もっと読み込む',
						search_label: 'この サイト 内 を 検索',
						filters_label: 'フィルター',
						zero_results: '[SEARCH_TERM]の検索結果はありませんでした',
						many_results: '[SEARCH_TERM]の検索結果：[COUNT]件',
						one_result: '[SEARCH_TERM]の検索結果：1件',
						alt_search: '[SEARCH_TERM]の結果は見つかりませんでした。代わりに[DIFFERENT_TERM]の結果を表示',
						search_suggestion: '[SEARCH_TERM]の結果は見つかりませんでした。別のキーワードをお試しください',
						searching: '[SEARCH_TERM]を検索中...'
					}
				});
			});
		</script>
		<style>
			main { width: 860px; max-width: calc(100% - 2rem); margin: 0 auto; padding: 2rem 1rem 4rem; }
			.breadcrumbs { font-size: 0.88em; color: rgb(var(--gray)); margin-bottom: 1rem; }
			.breadcrumbs a { color: var(--accent); text-decoration: none; }
			.lead { color: rgb(var(--gray-dark)); line-height: 1.9; margin: 0 0 2rem; }
			.search-wrap { margin-top: 2rem; }
			/* Pagefind UI customization */
			:global(.pagefind-ui) {
				--pagefind-ui-primary: var(--accent);
				--pagefind-ui-text: rgb(var(--black));
				--pagefind-ui-background: var(--bg);
				--pagefind-ui-border: rgb(var(--gray-light));
				--pagefind-ui-border-radius: 8px;
				--pagefind-ui-font: 'Noto Sans JP', sans-serif;
			}
		</style>
	</body>
</html>
