		solution: 'LanguageApp.translate 一括処理',
		timeSaved: '1時間/回',
		level: 'easy',
		keywords: ['spreadsheet', 'translate'],
		category: 'spreadsheet',
		personas: ['翻訳者', '海外取引'],
	},

	// === SIDE BUSINESS / TAX ===
	{
		id: 'ubereats-mf-csv',
		scene: 'Uber Eats配達記録を確定申告用CSV化',
		problem: '配達スクショからの手入力で何時間も溶かす',
		solution: 'OCR→マネーフォワード形式CSV出力',
		timeSaved: '5時間/月',
