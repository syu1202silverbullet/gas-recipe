		timeSaved: '2時間/月',
		level: 'mid',
		keywords: ['side-business', 'invoice'],
		category: 'side-business',
		personas: ['フリーランス', '副業ワーカー'],
	},
	{
		id: 'amazon-fba-stock',
		scene: 'Amazon FBA在庫を毎朝スプシで監視',
		problem: '在庫切れに気付かず機会損失',
		solution: 'SP-API→スプシ自動記録→しきい値でLINE警告',
		timeSaved: '20分/日',
		level: 'hard',
		keywords: ['side-business', 'amazon', 'stock'],
		category: 'side-business',
		personas: ['物販事業者'],
	},
	{
		id: 'mercari-sales',
		scene: 'メルカリ売上を毎月自動集計',
		problem: '取引履歴を手作業でまとめるのが面倒',
