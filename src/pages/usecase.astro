		solution: 'スプシ差し込み+送信済みフラグ管理',
		timeSaved: '3時間/回',
		level: 'mid',
		keywords: ['gmail', 'bulk-send'],
		category: 'gmail',
		personas: ['EC運営者', '講師'],
	},

	// === CALENDAR ===
	{
