---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileNav from '../components/MobileNav.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const now = new Date();
const posts = (await getCollection('blog'))
	.filter((p: any) => p.data.pubDate.valueOf() <= now.valueOf());

// ユースケースは業務シーンから探す逆引きインデックス
const useCases = [
	{ scene: '毎朝決まった時間にメール送信したい', keywords: ['gmail', 'morning', 'trigger'], category: 'gmail' },
	{ scene: '大量データの集計・自動更新', keywords: ['spreadsheet', 'automation'], category: 'spreadsheet' },
	{ scene: 'レシートや領収書の整理', keywords: ['ocr', 'receipt', 'tax'], category: 'side-business' },
	{ scene: '家族やチームにLINE通知', keywords: ['line', 'notification'], category: 'line' },
	{ scene: '予定・スケジュール管理', keywords: ['calendar', 'event'], category: 'calendar' },
	{ scene: 'フォーム送信時の自動処理', keywords: ['form', 'automation'], category: null },
	{ scene: 'エラーが出たときの対処', keywords: ['error', 'debug'], category: 'gas-basics' },
	{ scene: 'GASで副業を始めたい', keywords: ['side-business', 'freelance'], category: 'side-business' },
	{ scene: '毎朝のLINEリマインダー', keywords: ['line', 'reminder'], category: 'line' },
	{ scene: '確定申告の書類管理', keywords: ['tax', 'receipt', 'invoice'], category: 'side-business' },
];

function findArticles(uc: any) {
	return posts.filter((p: any) => {
		const catMatch = uc.category && p.data.categorySlug === uc.category;
		const tagMatch = (p.data.tagSlugs || []).some((t: string) => uc.keywords.includes(t));
		return catMatch || tagMatch;
	}).slice(0, 3);
}
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`ユースケース逆引き｜${SITE_TITLE}`} description="「毎朝メール送信したい」「レシートを自動整理したい」など、業務シーンから該当レシピを探せるGAS逆引きインデックスです。" />
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumbs" aria-label="パンくずリスト">
				<a href="/">ホーム</a> <span>›</span> ユースケース逆引き
			</nav>
			<h1>ユースケース逆引き</h1>
			<p class="lead">「こんなことを自動化したい」というシーンから、該当するGASレシピを探せるインデックスです。</p>

			<div class="uc-grid">
				{useCases.map((uc) => {
					const articles = findArticles(uc);
					if (articles.length === 0) return null;
					return (
						<div class="uc-card">
							<h2>{uc.scene}</h2>
							<ul>
								{articles.map((a: any) => (
									<li><a href={`/blog/${a.id}/`}>{a.data.title}</a></li>
								))}
							</ul>
						</div>
					);
				})}
			</div>
		</main>
		<Footer />
		<MobileNav />
		<style>
			main { width: 960px; max-width: calc(100% - 2rem); margin: 0 auto; padding: 2rem 1rem 4rem; }
			.breadcrumbs { font-size: 0.88em; color: rgb(var(--gray)); margin-bottom: 1rem; }
			.breadcrumbs a { color: var(--accent); text-decoration: none; }
			.lead { color: rgb(var(--gray-dark)); line-height: 1.9; margin: 0 0 2rem; }
			.uc-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
			.uc-card {
				background: var(--bg);
				border: 1px solid rgb(var(--gray-light));
				border-left: 4px solid var(--accent);
				border-radius: var(--radius);
				padding: 1.3rem 1.5rem;
			}
			.uc-card h2 {
				font-size: 1.05em;
				margin: 0 0 0.8rem;
				padding: 0;
				border: none;
				background: none;
				color: rgb(var(--black));
			}
			.uc-card ul { list-style: none; padding: 0; margin: 0; }
			.uc-card li { margin-bottom: 0.5em; }
			.uc-card a { color: var(--accent); text-decoration: none; font-size: 0.93em; }
			.uc-card a:hover { text-decoration: underline; }
		</style>
	</body>
</html>
