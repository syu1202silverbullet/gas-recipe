// 記事検索ロジック
function findArticles(uc: UseCase) {
	return posts.filter((p: any) => {
		const catMatch = uc.category && p.data.categorySlug === uc.category;
		const tagMatch = (p.data.tagSlugs || []).some((t: string) => uc.keywords.includes(t));
		return catMatch || tagMatch;
	}).slice(0, 3);
}

// ペルソナ集計
const allPersonas = [...new Set(useCases.flatMap(uc => uc.personas))];

// 難易度ラベル
const levelLabel = {
	easy: { text: '初級', color: '#10b981' },
	mid: { text: '中級', color: '#f59e0b' },
	hard: { text: '上級', color: '#dc2626' },
};

// シーンカテゴリでグループ化
const sceneGroups = [
	{
		title: '⏰ 朝・日次ルーティン',
		ids: ['morning-line', 'weather-morning', 'daily-todo-line'],
	},
	{
		title: '✉️ Gmail自動化',
		ids: ['gmail-auto-reply', 'gmail-receipt-extract', 'gmail-attachment-drive', 'gmail-bulk-send'],
	},
	{
		title: '📅 カレンダー・予定管理',
		ids: ['calendar-bulk-import', 'calendar-form-booking', 'calendar-birthday'],
	},
	{
		title: '📊 スプレッドシート自動化',
		ids: ['sheet-pdf-monthly', 'sheet-dashboard', 'sheet-dedupe', 'sheet-csv-import', 'sheet-stock-price', 'sheet-translate'],
	},
	{
		title: '💼 副業・確定申告',
		ids: ['ubereats-mf-csv', 'receipt-ocr', 'freelance-invoice', 'amazon-fba-stock', 'mercari-sales'],
	},
	{
		title: '💬 LINE連携',
		ids: ['line-chatgpt-bot', 'line-reply-bot'],
	},
	{
		title: '📝 フォーム処理',
		ids: ['form-cert-pdf', 'form-slack-notify'],
	},
	{
		title: '📁 ドライブ・バックアップ',
		ids: ['drive-backup', 'drive-cleanup'],
	},
	{
		title: '🌐 Webアプリ',
		ids: ['webapp-form-db'],
	},
	{
		title: '🩹 困ったときの対処',
		ids: ['error-quick', 'gas-start'],
	},
];

const useCaseMap = Object.fromEntries(useCases.map(uc => [uc.id, uc]));
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`GASユースケース逆引き（${useCases.length}シーン） | ${SITE_TITLE}`}
			description={`「毎朝LINEで通知したい」「レシートを自動記帳したい」「Uber Eats確定申告を楽にしたい」など、やりたいことからGASレシピを探せる${useCases.length}シーンの逆引きインデックス。現役ナース×副業Webエンジニアの凛が運営中。`}
		/>
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumbs" aria-label="パンくずリスト">
				<a href="/">ホーム</a> <span>›</span> ユースケース逆引き
			</nav>

			<!-- HERO -->
			<section class="uc-hero">
				<p class="eyebrow">🎯 Use Case Index</p>
				<h1>GASユースケース逆引き<br/>「やりたいこと」から探す</h1>
				<p class="lead">
					「こんな自動化したい」というシーンから、該当するGASレシピを<strong>即座に</strong>探せるインデックス。
					全<strong>{useCases.length}シーン</strong>を業務の種類・難易度・節約時間付きで整理しました。
				</p>
				<div class="uc-stats">
					<div class="stat"><strong>{useCases.length}</strong><span>ユースケース</span></div>
					<div class="stat"><strong>{sceneGroups.length}</strong><span>シーン分類</span></div>
					<div class="stat"><strong>{allPersonas.length}+</strong><span>対応ペルソナ</span></div>
				</div>
			</section>

			<!-- JUMP NAV -->
			<nav class="jump-nav" aria-label="シーン一覧">
				{sceneGroups.map((g, i) => (
					<a href={`#scene-${i}`} class="jump-chip">{g.title}</a>
				))}
			</nav>

			<!-- PERSONA SECTION -->
			<section class="persona-box">
				<h2>👥 こんな方におすすめのユースケースが揃っています</h2>
				<div class="persona-tags">
					{allPersonas.map(p => <span class="persona-tag">{p}</span>)}
				</div>
			</section>

			<!-- USECASE GROUPS -->
			{sceneGroups.map((group, gi) => (
				<section class="uc-group" id={`scene-${gi}`}>
					<h2 class="group-title">{group.title}</h2>
					<div class="uc-grid">
						{group.ids.map(id => {
							const uc = useCaseMap[id];
							if (!uc) return null;
							const articles = findArticles(uc);
							const lbl = levelLabel[uc.level];
							return (
								<article class="uc-card">
									<div class="uc-top">
										<span class="uc-level" style={`background: ${lbl.color}`}>{lbl.text}</span>
										<span class="uc-time">⏱ {uc.timeSaved}節約</span>
									</div>
									<h3>{uc.scene}</h3>
									<p class="uc-problem"><strong>❓ よくある悩み:</strong> {uc.problem}</p>
									<p class="uc-solution"><strong>💡 解決方法:</strong> {uc.solution}</p>
									{articles.length > 0 && (
										<div class="uc-articles">
											<p class="uc-art-label">📄 該当レシピ:</p>
											<ul>
												{articles.map((a: any) => (
													<li><a href={`/blog/${a.id}/`}>{a.data.title}</a></li>
												))}
											</ul>
										</div>
									)}
									{articles.length === 0 && (
										<p class="uc-coming">📝 このユースケースの記事は執筆予定です</p>
									)}
								</article>
							);
						})}
					</div>
				</section>
			))}

			<!-- MID CTA -->
			<section class="mid-cta">
				<div class="cta-inner">
					<p class="cta-eyebrow">🛍️ 学習の時間が取れない方へ</p>
					<h2>完成済みテンプレートを使うという選択</h2>
					<p>
						「自分で書く時間はないけど、自動化の恩恵は欲しい」方向けに、凛が毎日使っているGASの仕組みを6本のテンプレートとしてパッケージ化中。
						事前登録いただいた方にリリース案内をお送りします。
					</p>
