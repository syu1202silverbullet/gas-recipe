---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileNav from '../components/MobileNav.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const now = new Date();
const posts = (await getCollection('blog'))
	.filter((p: any) => p.data.pubDate.valueOf() <= now.valueOf());

// ユースケース：シーン×ペルソナ×技術カテゴリで網羅
type UseCase = {
	id: string;
	scene: string;
	problem: string;
	solution: string;
	timeSaved: string;
	level: 'easy' | 'mid' | 'hard';
	keywords: string[];
	category: string | null;
	personas: string[];
};

const useCases: UseCase[] = [
	// === DAILY ROUTINE ===
	{
		id: 'morning-line',
		scene: '毎朝7時に今日の予定をLINEで自分に通知したい',
		problem: 'スマホのカレンダーは開くのが面倒、重要な予定を見落とす',
		solution: 'GASでカレンダー→LINE Messaging API連携、時間主導トリガー',
		timeSaved: '10分/日',
		level: 'easy',
		keywords: ['line', 'calendar', 'notification', 'reminder'],
		category: 'line',
		personas: ['忙しい人', '副業ワーカー', '会社員'],
	},
	{
		id: 'weather-morning',
		scene: '朝、今日の天気予報を自動でLINEに届けたい',
		problem: '天気アプリを毎朝開くのが地味に面倒',
		solution: 'OpenWeatherMap API → GAS → LINE連携',
		timeSaved: '3分/日',
		level: 'mid',
		keywords: ['line', 'weather', 'api'],
		category: 'line',
		personas: ['家族持ち', '通勤者'],
	},
	{
		id: 'daily-todo-line',
		scene: '毎朝ToDoリストをLINEに通知してタスク抜け防止',
