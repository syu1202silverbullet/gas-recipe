		personas: ['チーム運営'],
	},

	// === DRIVE / OCR ===
	{
		id: 'drive-backup',
		scene: '重要スプシを毎週自動バックアップ',
		problem: '誤削除・誤編集で復旧できずパニック',
		solution: 'DriveApp.makeCopy 毎週トリガー',
		timeSaved: '大事故回避',
		level: 'easy',
