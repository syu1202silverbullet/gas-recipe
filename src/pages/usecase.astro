		solution: 'Gmail検索 → 自動返信+ラベル付与、5分トリガー',
		timeSaved: '30分/日',
		level: 'easy',
		keywords: ['gmail', 'auto-reply'],
		category: 'gmail',
		personas: ['個人事業主', 'EC運営者'],
	},
	{
		id: 'gmail-receipt-extract',
