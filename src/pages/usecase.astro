		personas: ['店舗運営', '副業ワーカー'],
	},

	// === FORM ===
	{
		id: 'form-cert-pdf',
		scene: 'フォーム回答者に修了証PDFを自動発行',
		problem: 'オンライン講座の修了証を1人ずつ作るのが非現実的',
		solution: 'フォーム送信→テンプレ流し込み→PDF→メール送信',
		timeSaved: '30分/人',
		level: 'hard',
		keywords: ['form', 'pdf', 'cert'],
		category: null,
		personas: ['講師', 'オンライン講座'],
	},
	{
		id: 'form-slack-notify',
