---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const now = new Date();
	const posts = (await getCollection('blog'))
		.filter((p: any) => p.data.pubDate.valueOf() <= now.valueOf());

	const categories = new Map<string, { displayName: string; posts: typeof posts }>();
	posts.forEach((p: any) => {
		const slug = p.data.categorySlug;
		const name = p.data.categoryName;
		if (!slug || !name) return;
		if (!categories.has(slug)) categories.set(slug, { displayName: name, posts: [] });
		categories.get(slug)!.posts.push(p);
	});

	return Array.from(categories.entries()).map(([slug, { displayName, posts: cposts }]) => ({
		params: { slug },
		props: { displayName, posts: cposts.sort((a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()) },
	}));
}

const { displayName, posts } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`${displayName}の記事一覧 | ${SITE_TITLE}`} description={`${displayName}カテゴリの記事を新着順で表示しています。`} />
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumbs" aria-label="パンくずリスト">
				<a href="/">ホーム</a> <span>›</span>
				<a href="/blog/">記事一覧</a> <span>›</span>
				カテゴリ「{displayName}」
			</nav>
			<h1>「{displayName}」の記事一覧</h1>
			<p class="count">{posts.length}件の記事</p>
			<ul class="post-list">
				{posts.map((post: any) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
							<span class="post-title">{post.data.title}</span>
							<span class="post-desc">{post.data.description}</span>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
		<style>
			main { width: 860px; max-width: calc(100% - 2rem); padding: 2rem 1rem 4rem; }
			.breadcrumbs { font-size: 0.88em; color: rgb(var(--gray)); margin-bottom: 1rem; }
			.breadcrumbs a { color: var(--accent); text-decoration: none; }
			.count { color: rgb(var(--gray)); font-size: 0.9em; }
			.post-list { list-style: none; padding: 0; display: grid; grid-template-columns: 1fr; gap: 1rem; margin-top: 1.5rem; }
			.post-list li { background: var(--bg); border: 1px solid rgb(var(--gray-light)); border-radius: var(--radius); }
			.post-list a { display: block; padding: 1.2rem; text-decoration: none; color: inherit; border: none; transition: all 0.15s; }
			.post-list a:hover { transform: translateY(-2px); box-shadow: var(--box-shadow); }
			.post-date { display: block; font-size: 0.82em; color: rgb(var(--gray)); margin-bottom: 0.3rem; }
			.post-title { display: block; font-weight: 700; font-size: 1.05em; color: rgb(var(--black)); margin-bottom: 0.4rem; }
			.post-desc { display: block; font-size: 0.88em; color: rgb(var(--gray-dark)); line-height: 1.6; }
		</style>
	</body>
</html>
